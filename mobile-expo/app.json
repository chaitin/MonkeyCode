{
  "expo": {
    "name": "MonkeyCode",
    "slug": "monkeycode",
    "version": "260606",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "monkeycode",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chaitin.baizhi.monkeycode",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "用于语音输入，将你的语音实时转写为文字",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.chaitin.baizhi.monkeycode",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "./plugins/withFmtFix",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/splash-dark.png",
            "backgroundColor": "#0b0b0e"
          }
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
